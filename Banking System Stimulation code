#include <iostream>
#include <vector>
using namespace std;

// Structure to store account details
struct Account {
    int accNo;
    string name;
    double balance;
    string pin;
};

// Global variables
vector<Account> accounts;
int accCounter = 1001;

// Function to find account index
int findAccount(int accNo) {
    for (int i = 0; i < accounts.size(); i++) {
        if (accounts[i].accNo == accNo)
            return i;
    }
    return -1;
}

// Create Account
void createAccount() {
    Account acc;
    acc.accNo = accCounter++;

    cout << "Enter Name: ";
    cin >> acc.name;

    cout << "Enter Initial Deposit: ";
    cin >> acc.balance;

    cout << "Set 4-digit PIN: ";
    cin >> acc.pin;

    accounts.push_back(acc);

    cout << "Account created successfully!\n";
    cout << "Your Account Number: " << acc.accNo << endl;
}

// Deposit Money
void deposit() {
    int accNo;
    cout << "Enter Account Number: ";
    cin >> accNo;

    int index = findAccount(accNo);

    if (index != -1) {
        double amount;
        cout << "Enter amount to deposit: ";
        cin >> amount;

        accounts[index].balance += amount;

        cout << "Deposit successful!\n";
        cout << "Updated Balance: " << accounts[index].balance << endl;
    } else {
        cout << "Account not found!\n";
    }
}

// Withdraw Money
void withdraw() {
    int accNo;
    string pin;

    cout << "Enter Account Number: ";
    cin >> accNo;

    cout << "Enter PIN: ";
    cin >> pin;

    int index = findAccount(accNo);

    if (index != -1 && accounts[index].pin == pin) {
        double amount;
        cout << "Enter amount to withdraw: ";
        cin >> amount;

        if (accounts[index].balance >= amount) {
            accounts[index].balance -= amount;
            cout << "Withdrawal successful!\n";
            cout << "Remaining Balance: " << accounts[index].balance << endl;
        } else {
            cout << "Insufficient balance!\n";
        }
    } else {
        cout << "Invalid account or PIN!\n";
    }
}

// Check Balance
void checkBalance() {
    int accNo;
    string pin;

    cout << "Enter Account Number: ";
    cin >> accNo;

    cout << "Enter PIN: ";
    cin >> pin;

    int index = findAccount(accNo);

    if (index != -1 && accounts[index].pin == pin) {
        cout << "Account Holder: " << accounts[index].name << endl;
        cout << "Balance: " << accounts[index].balance << endl;
    } else {
        cout << "Invalid account or PIN!\n";
    }
}

// Transfer Money
void transfer() {
    int sender, receiver;
    string pin;

    cout << "Enter Sender Account Number: ";
    cin >> sender;

    cout << "Enter Receiver Account Number: ";
    cin >> receiver;

    cout << "Enter Sender PIN: ";
    cin >> pin;

    int sIndex = findAccount(sender);
    int rIndex = findAccount(receiver);

    if (sIndex != -1 && rIndex != -1) {
        if (accounts[sIndex].pin == pin) {
            double amount;
            cout << "Enter amount to transfer: ";
            cin >> amount;

            if (accounts[sIndex].balance >= amount) {
                accounts[sIndex].balance -= amount;
                accounts[rIndex].balance += amount;

                cout << "Transfer successful!\n";
                cout << "Sender Balance: " << accounts[sIndex].balance << endl;
            } else {
                cout << "Insufficient balance!\n";
            }
        } else {
            cout << "Incorrect PIN!\n";
        }
    } else {
        cout << "Invalid account details!\n";
    }
}

// Main Function
int main() {
    int choice;

    do {
        cout << "\n===== Banking System Menu =====\n";
        cout << "1. Create Account\n";
        cout << "2. Deposit Money\n";
        cout << "3. Withdraw Money\n";
        cout << "4. Check Balance\n";
        cout << "5. Transfer Money\n";
        cout << "6. Exit\n";

        cout << "Enter your choice: ";
        cin >> choice;

        switch (choice) {
            case 1: createAccount(); break;
            case 2: deposit(); break;
            case 3: withdraw(); break;
            case 4: checkBalance(); break;
            case 5: transfer(); break;
            case 6: cout << "Thank you for using Banking System!\n"; break;
            default: cout << "Invalid choice!\n";
        }

    } while (choice != 6);

    return 0;
}
